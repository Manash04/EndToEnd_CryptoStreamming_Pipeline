FROM apache/airflow:2.8.0

USER root

# Install Java
RUN apt-get update && \
    apt-get install -y openjdk-17-jdk-headless procps && \
    apt-get clean

# Copy Spark directly from the apache/spark image
COPY --from=apache/spark:3.5.0 /opt/spark /opt/spark

# Create ivy cache directory with correct ownership
RUN mkdir -p /home/airflow/.ivy2/cache /home/airflow/.ivy2/jars && \
    chown -R airflow:root /home/airflow/.ivy2 && \
    chmod -R 775 /home/airflow/.ivy2

# Fix spark ownership
RUN chown -R airflow:root /opt/spark && \
    chmod -R 775 /opt/spark

ENV SPARK_HOME=/opt/spark
ENV PATH=$PATH:/opt/spark/bin
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

USER airflow

RUN pip install \
    azure-storage-file-datalake \
    psycopg2-binary