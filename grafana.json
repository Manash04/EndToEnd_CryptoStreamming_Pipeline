{
  "title": "Crypto Pipeline Monitoring",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Kafka Consumer Lag over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT recorded_at AS time, consumer_lag, topic AS metric FROM pipeline_metrics WHERE $__timeFilter(recorded_at) AND query_name = 'kafka_lag' ORDER BY recorded_at ASC",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Current Consumer Lag per Topic",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT topic, consumer_lag FROM pipeline_metrics WHERE recorded_at = (SELECT MAX(recorded_at) FROM pipeline_metrics) AND query_name = 'kafka_lag' ORDER BY consumer_lag DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "title": "Last Metrics Collection",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT MAX(recorded_at) AS \"Last heartbeat\" FROM pipeline_metrics",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Metrics Collected",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Total records\" FROM pipeline_metrics",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Lag across all topics",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT recorded_at AS time, SUM(consumer_lag) AS total_lag FROM pipeline_metrics WHERE $__timeFilter(recorded_at) AND query_name = 'kafka_lag' GROUP BY recorded_at ORDER BY recorded_at ASC",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    }
  ]
}